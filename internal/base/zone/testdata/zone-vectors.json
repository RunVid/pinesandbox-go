      }
    },
    {
      "input": "staging.pinesandbox.io",
      "control_host": "api.staging.pinesandbox.io",
      "http_scheme": "https",
      "data_hosts": {
        "pc0abc": "pc0abc.computer.staging.pinesandbox.io"
      }
    },
    {
      "input": "https://staging.pinesandbox.io/app/login",
      "control_host": "api.staging.pinesandbox.io",
      "http_scheme": "https",
      "data_hosts": {
        "sbx-1": "sbx-1.computer.staging.pinesandbox.io"
      },
      "note": "URL paths are dropped"
    },
    {
      "input": "pinesandbox.io",
      "control_host": "api.pinesandbox.io",
