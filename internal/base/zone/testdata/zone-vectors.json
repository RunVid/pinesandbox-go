  "invalid_endpoints": [
    {
      "input": "",
      "reason": "empty"
    },
    {
      "input": "localhost",
      "reason": "local zone requires a port"
    },
    {
      "input": "api.staging.pinesandbox.io",
      "reason": "control host is DERIVED — pass the base endpoint"
    },
    {
      "input": "sbx-1.computer.staging.pinesandbox.io",
      "reason": "Computer host is DERIVED — pass the base endpoint"
    },
