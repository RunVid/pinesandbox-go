    {
      "input": "localhost:18080",
      "reason": "bare localhost has no dot (ZONE_RE requires one) — use a *.localhost subdomain. NOTE: zone.rb's secure? bare-localhost branch is therefore unreachable; doc/dead-code cleanup candidate (Phase 2)."
    }
  ],
  "invalid_sandbox_ids": [
    "",
    "UPPER",
    "has_underscore",
    "-leading",
    "trailing-",
    "a--b",
    "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  ]
